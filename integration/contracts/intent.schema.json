{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urlog.local/integration/intent.schema.json",
  "title": "Integration Intent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "created_at",
    "selected_by",
    "action_id",
    "target",
    "environment_id",
    "reason",
    "evidence_refs"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "minLength": 8
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "selected_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["llm", "human", "policy", "scheduler"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "environment_id": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 12
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "ref"],
        "properties": {
          "type": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "requested_ttl_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1440
    }
  }
}
